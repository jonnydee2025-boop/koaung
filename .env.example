# Copy to .env and fill in (never commit .env)

TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=dhamma_tracks

GOOGLE_CLIENT_SECRET_FILE=client_secret.json
GOOGLE_TOKEN_FILE=token.json

BACKGROUND_VIDEO_DRIVE_FOLDER=
# Optional path for row-range rules JSON (default: row_range_rules.json in project root)
ROW_RULES_PATH=row_range_rules.json
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
TMP_ROOT=tmp_video_jobs
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000

ENABLE_AUDIO_ENHANCE=true

# Long random secret; required for admin API
ADMIN_API_KEY=

# Dev: http://localhost:5173,http://127.0.0.1:5173
# Production: https://your-domain.com
ADMIN_API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# How often the bot checks for due Scheduled rows (seconds)
SCHEDULE_CHECK_INTERVAL_SECONDS=30

# Optional: Gemini-generated Burmese YouTube description + SEO tags before upload
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MODEL_FALLBACKS=gemini-2.0-flash
