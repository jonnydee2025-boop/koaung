# ── Secrets & local config (never commit) ─────────────────────────────────────
.env
.env.local
.env.*.local
admin-panel/.env
admin-panel/.env.build
admin-panel/.env.deploy-backup
token.json
client_secret.json
deploy/deploy.local.env
deploy/deploy.secrets.env
deploy/deploy_key
deploy/deploy_key.pub

# Keep templates (*.example) — they are safe to commit
!.env.example
!**/*.example

# ── Dependencies & build output (reinstall / rebuild on each machine) ───────
node_modules/
**/node_modules/
dist/
**/dist/
dist-ssr/
**/dist-ssr/
.vite/
**/.vite/

# ── Python ───────────────────────────────────────────────────────────────────
.venv/
venv/
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# ── Bot runtime temp files ─────────────────────────────────────────────────────
tmp_video_jobs/
row_range_rules.json
interval_triggers.json
repeat_jobs.json
gemini_models.json

# ── OS & editors ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ── Logs & caches ────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Archives / local deploy artifacts ─────────────────────────────────────────
*.tar.gz
videobot-deploy.tar.gz
