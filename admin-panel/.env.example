# Copy to admin-panel/.env (never commit admin-panel/.env)
#
# Local dev: optional — skips login if set (matches ADMIN_API_KEY in root .env)
# Production build: leave empty — users sign in on the login screen
VITE_ADMIN_API_KEY=

# Leave empty for Vite dev proxy and nginx same-origin production
VITE_API_BASE_URL=
