# VideoBot production environment (Linux VPS)
# Copy to /opt/videobot/.env and fill in all values.

TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=dhamma_tracks

GOOGLE_CLIENT_SECRET_FILE=/opt/videobot/client_secret.json
GOOGLE_TOKEN_FILE=/opt/videobot/token.json

BACKGROUND_VIDEO_DRIVE_FOLDER=
ROW_RULES_PATH=/opt/videobot/row_range_rules.json
THUMBNAIL_TEMPLATE=/opt/videobot/assets/thumbnail_template.jpg
THUMBNAIL_FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf

FFMPEG_BIN=/usr/bin/ffmpeg
FFPROBE_BIN=/usr/bin/ffprobe
TMP_ROOT=/opt/videobot/tmp_video_jobs
LOG_LEVEL=INFO

# API listens only on localhost; nginx proxies /api to this port.
API_HOST=127.0.0.1
API_PORT=8000

ENABLE_AUDIO_ENHANCE=true

# Generate with: openssl rand -hex 32
ADMIN_API_KEY=

# Your public site URL (same origin as nginx — no trailing slash)
ADMIN_API_CORS_ORIGINS=https://YOUR_DOMAIN.com

SCHEDULE_CHECK_INTERVAL_SECONDS=30

# Optional: Gemini-generated Burmese YouTube description + SEO tags before upload
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
