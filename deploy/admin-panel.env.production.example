# Admin panel production build (Vite)
# Copy to admin-panel/.env before: npm run build
#
# Must match ADMIN_API_KEY in /opt/videobot/.env

VITE_ADMIN_API_KEY=

# Leave empty when nginx serves the UI and /api on the same domain (recommended).
# Set only if the API is on a different host, e.g. https://api.your-domain.com
VITE_API_BASE_URL=
