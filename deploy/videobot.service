[Unit]
Description=VideoBot — Telegram automation + admin API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=videobot
Group=videobot
WorkingDirectory=/opt/videobot
EnvironmentFile=/opt/videobot/.env
ExecStartPre=/bin/mkdir -p /opt/videobot/tmp_video_jobs
ExecStartPre=/bin/sh -c 'test -f /opt/videobot/repeat_jobs.json || echo "{\"jobs\": {}}" > /opt/videobot/repeat_jobs.json'
ExecStart=/opt/videobot/.venv/bin/python /opt/videobot/video_automation_bot.py
Restart=on-failure
RestartSec=10
TimeoutStopSec=120

# FFmpeg renders can use significant memory
MemoryMax=4G

# Hardening (adjust if you add writable paths outside these)
NoNewPrivileges=true
PrivateTmp=true
ReadWritePaths=/opt/videobot/tmp_video_jobs /opt/videobot/token.json /opt/videobot/repeat_jobs.json /opt/videobot/row_range_rules.json

[Install]
WantedBy=multi-user.target
